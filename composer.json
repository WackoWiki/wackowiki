{
	"name" : "wackowiki/wackowiki",
	"description" : "WackoWiki is a light and handy Wiki-engine.",
	"type" : "project",
	"keywords" : [
		"wackowiki",
		"wiki"
	],
	"homepage" : "https://wackowiki.org",
	"license" : "BSD-3-Clause",
	"require" : {
		"php" : "8.0 - 8.5",
		"ext-bcmath" : "*",
		"ext-ctype" : "*",
		"ext-dom" : "*",
		"ext-fileinfo" : "*",
		"ext-gd" : "*",
		"ext-iconv" : "*",
		"ext-intl" : "*",
		"ext-json" : "*",
		"ext-mbstring" : "*",
		"ext-mysqli" : "*",
		"ext-openssl" : "*",
		"ext-pcre" : "*",
		"ext-pdo" : "*",
		"ext-pdo_mysql" : "*",
		"ext-SPL" : "*",
		"ext-sqlite3" : "*",
		"ext-zlib" : "*",
		"phiki/phiki": "^2.0",
		"hashids/hashids": "^5.0",
		"jblond/php-diff": "^2.5",
		"phpmailer/phpmailer": "^7.0",
		"phpthumb/phpthumb": "^2.3",
		"simplepie/simplepie": "^1.9",
		"enshrined/svg-sanitize": "^0.22"
	},
	"prefer-stable" : true,
	"config" : {
		"vendor-dir" : "src/vendor",
		"optimize-autoloader": true,
		"sort-packages": true
	}
}