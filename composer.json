{
	"name" : "wackowiki/wackowiki",
	"description" : "WackoWiki is a light and handy Wiki-engine.",
	"type" : "project",
	"keywords" : [
		"wackowiki",
		"wiki"
	],
	"homepage" : "https://wackowiki.org",
	"license" : "BSD-3-Clause",
	"require" : {
		"php" : "8.3 - 8.5",
		"ext-SPL" : "*",
		"ext-bcmath" : "*",
		"ext-ctype" : "*",
		"ext-dom" : "*",
		"ext-fileinfo" : "*",
		"ext-gd" : "*",
		"ext-iconv" : "*",
		"ext-intl" : "*",
		"ext-json" : "*",
		"ext-mbstring" : "*",
		"ext-mysqli" : "*",
		"ext-openssl" : "*",
		"ext-pcre" : "*",
		"ext-pdo" : "*",
		"ext-pdo_mysql" : "*",
		"ext-sqlite3" : "*",
		"ext-zlib" : "*",
		"badbehaviour/badbehaviour" : "^2.3.0",
		"enshrined/svg-sanitize" : "^0.22",
		"hashids/hashids" : "^5.0",
		"jblond/php-diff" : "^2.5",
		"phiki/phiki" : "^2.0",
		"phpmailer/phpmailer" : "^7.0",
		"phpthumb/phpthumb" : "^2.3.5",
		"simplepie/simplepie" : "^1.9",
		"wackowiki/diff" : "^1.0",
		"wackowiki/freecap" : "^1.5.0",
		"wackowiki/safehtml" : "^1.4.2"
	},
	"prefer-stable" : true,
	"config" : {
		"vendor-dir" : "src/vendor",
		"optimize-autoloader" : true,
		"sort-packages" : true
	}
}
