[ === main === ]
<ignore>
<!--notypo-->
<div class="hl-code">
	<div class="hl-header">
		<span class="hl-language">[ ' language ' ]</span>
		<button type="button" class="clipb hl-copy-btn" 
				title="[ ' _t: SourceCopyToClipboard ' ]" 
				data-clipboard-target="#[ ' token ' ]">
			<img src="[ ' db: theme_url ' ]icon/spacer.png" 
				 class="ico-copy ico-sm" 
				 alt="Copy">
		</button>
	</div>
	<div class="hl-body">
		[ ' text | pre ' ]
	</div>
</div>
<!--/notypo-->
</ignore>